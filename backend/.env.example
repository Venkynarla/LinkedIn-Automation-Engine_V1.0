# Copy this file, fill in your real values, and either:
#   (a) paste the filled-in contents into Render → your service → Environment
#       tab → "Add from .env" / bulk paste option, OR
#   (b) add each line one-by-one as individual environment variables.
#
# Never commit a filled-in version of this file to GitHub — keep it local only,
# or rename it to .env and make sure .env is in your .gitignore.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Not used by the backend yet (Apify scraper isn't built), but reserve it
# now so you don't have to hunt for this step again later:
APIFY_API_TOKEN=your-apify-token-here
